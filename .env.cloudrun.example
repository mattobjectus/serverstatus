# Example environment variables for Cloud Run deployment
# Copy this file and configure with your actual values

# Google Cloud Storage
BUCKET_NAME=your-bucket-name
BUCKET_FILE_PATH=serviceChk_finprodcoredc2.txt
PROJECT_NAME=your-gcp-project-id

# Note: GOOGLE_APPLICATION_CREDENTIALS is not needed in Cloud Run
# Cloud Run uses Workload Identity or service account attached to the service

# Instana Configuration
BASE_URL=https://your-instance.instana.io
API_TOKEN=your-instana-api-token
DASHBOARD_NAME=Finacle Monitor
WIDGET_NAME=Service Status
EVENT_DURATION=180000
MAX_SCHEDULED_INTERVAL_IN_MILLIS=60000
FINACLE_HOST=your-finacle-host

# Agent URLs
AGENT_URL=http://your-agent-ip:4001
OTLP_AGENT_URL=http://your-agent-ip:4000

# Cloud Run Configuration
AS_ENDPOINT=True
LOOP_PAUSE_IN_SECONDS=-1

# Optional: Use local file instead of bucket (for testing)
# USE_LOCAL_FILE_INSTEAD_OF_BUCKET_PATH=

# Optional: Skip event generation
# SKIP_EVENT_GENERATION=False
